# ==============================================================
# IPL AI Predictor — Environment Variables
# ==============================================================

# Anthropic Claude API Key (required for AI predictions)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Cron job secret (protects the /api/cron endpoint)
CRON_SECRET=your-secret-key-here

# Database path (defaults to ./data/ipl.db)
# DATABASE_PATH=./data/ipl.db
